program expresiones{

    //Creamos variables y les asignamos como valor diferentes operaciones aritmeticas
    var a = 2 + 3;
    var b = 3 - 2;
    var c = 2 * 3;
    var d = 10 / 2;
    var e = 2 + 2 * 4;
    var f = a + b;

    println a;
    println b;
    println c;
    println d;
    println e;
    println f;

}